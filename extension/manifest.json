{
  "manifest_version": 3,
  "name": "Contxt",
  "version": "0.1.0",
  "description": "Portable, privacy-first context layer for every AI.",
  "permissions": ["storage", "offscreen", "identity"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://api.fireworks.ai/*",
    "https://www.googleapis.com/*",
    "https://api.notion.com/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Contxt",
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://blackx16.github.io/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["site-connect.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
