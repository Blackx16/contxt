{
  "manifest_version": 3,
  "name": "Contxt",
  "version": "0.1.0",
  "description": "Portable, privacy-first context layer for every AI.",
  "permissions": ["storage", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_title": "Contxt" }
}
