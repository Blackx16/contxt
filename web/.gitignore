node_modules

# The repo-root .gitignore has a Python `lib/` rule; SvelteKit's src/lib is app
# source (the $lib alias) and MUST be tracked. Re-include it here.
!src/lib/
!src/lib/**

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

