# Cloud Gemma — SHARED tier distillation + draft_reply
# Fireworks AI (default): https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# AMD Dev Cloud endpoint (overrides Fireworks when set).
# Required for "Best AMD-Hosted Gemma Project" prize track ($2k).
# Set to your AMD AI Cloud inference URL, e.g.:
#   https://api.amd.developer.cloud/v1/chat/completions
AMD_CLOUD_ENDPOINT=

# Gemma model to use on the cloud endpoint.
# Fireworks default: accounts/fireworks/models/gemma-3-27b-it
GEMMA_CLOUD_MODEL=accounts/fireworks/models/gemma-3-27b-it

# Offline / demo controls (see docs/AMD_PRIZE.md):
#   CONTXT_MOCK_GEMMA=1   force the deterministic mock (tests, offline demo)
#   CONTXT_MOCK_GEMMA=0   force the real call even with no key (will error if unset)
#   (unset)               auto-mock only when neither key nor AMD endpoint is wired
#   CONTXT_CACHE=0        disable the gateway/.cache response cache
CONTXT_MOCK_GEMMA=
CONTXT_CACHE=

# NOTE: distill.py logs every cloud call at INFO level:
#   contxt:cloud_gemma endpoint=… model=…
#   contxt:cloud_gemma_ok id=… usage=…
# Capture these for the AMD prize submission — see docs/AMD_PRIZE.md.
