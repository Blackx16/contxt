# ── CHA-19: Private-tier encryption key ──────────────────────────────────────
# 256-bit AES key, base64url-encoded (no padding).
# Generated automatically on first run if unset (printed to stderr).
# Copy this value into the browser via the key-sync / QR dialog so the
# web UI can decrypt PRIVATE cards. The cloud DB only ever holds ciphertext.
CONTXT_PRIVATE_KEY=

# SQLite store path (default: data/contxt.db, created automatically).
CONTXT_DB=data/contxt.db

# ── Cloud LLM — SHARED tier distillation + draft_reply ───────────────────────
# Fireworks AI: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# Optional: a custom OpenAI-compatible endpoint (overrides Fireworks when set):
#   https://<your-endpoint>/v1/chat/completions
CONTXT_CLOUD_ENDPOINT=

# Cloud model for SHARED-tier distillation (any Fireworks serverless chat model).
# Default = gpt-oss-120B. The on-device PRIVATE-tier model stays Gemma 3 270M.
#   accounts/fireworks/models/gpt-oss-120b   (default)
CONTXT_CLOUD_MODEL=accounts/fireworks/models/gpt-oss-120b

# Offline / demo controls:
#   CONTXT_MOCK_GEMMA=1   force the deterministic mock (tests, offline demo)
#   CONTXT_MOCK_GEMMA=0   force the real call even with no key (will error if unset)
#   (unset)               auto-mock only when no API key is wired
#   CONTXT_CACHE=0        disable the gateway/.cache response cache
CONTXT_MOCK_GEMMA=
CONTXT_CACHE=

# NOTE: distill.py logs every cloud call at INFO level:
#   contxt:cloud_llm endpoint=… model=…
#   contxt:cloud_llm_ok id=… usage=…

# ── Ingest: live source pulls (CHA-16) ────────────────────────────────────────
# All READ-ONLY. If unset, the ingest step uses the offline sample dump
# (ingest/samples/*.json) so the demo always runs. Live control:
#   CONTXT_INGEST_LIVE=1   force live for every source (still falls back on error)
#   CONTXT_INGEST_LIVE=0   force the offline sample dump (never hits the network)
#   (unset)                auto — live per-source only if its credentials are set
CONTXT_INGEST_LIVE=

# Google (Gmail + Calendar), read-only:
#   1. Google Cloud Console → create an OAuth client of type "Desktop app".
#   2. Enable the Gmail API and Google Calendar API on that project.
#   3. Download the client JSON → point GOOGLE_OAUTH_CLIENT at it.
#   4. First run opens a browser once for consent and writes GOOGLE_TOKEN.
GOOGLE_OAUTH_CLIENT=./secrets/google_client_secret.json
GOOGLE_TOKEN=./secrets/google_token.json

# Notion, read-only:
#   Create an internal integration at https://www.notion.so/my-integrations,
#   copy its token here, then SHARE the pages/databases to ingest with it.
NOTION_TOKEN=

# ── Extension OAuth (CHA-27: in-extension "Connect" onboarding) ───────────────
# The browser extension logs the user into Google + Notion directly. Google is a
# pure client-side implicit flow (needs only the client ID, entered in the popup).
# Notion's token exchange needs the client SECRET, so it happens on the bridge:
# the extension POSTs the auth code to /notion/exchange and the bridge swaps it.
#   1. Notion → https://www.notion.so/my-integrations → new PUBLIC integration.
#   2. Redirect URI = the extension's chrome.identity redirect
#      (shown in the popup's "Connection setup" panel: https://<id>.chromiumapp.org/).
#   3. Put the OAuth client id + secret here (Google's client id goes in the popup).
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_SECRET=
